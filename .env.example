# Spring profile
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/campus_facility_booking?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=123456

# Security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION_MILLIS=86400000

# File storage
FILE_UPLOAD_DIR=/app/files
FILE_BASE_URL=/files

# CORS
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
